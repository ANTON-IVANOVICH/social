NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
GRAPHQL_MAX_DEPTH=12
DATABASE_URL=postgresql://social:social@localhost:5432/social?schema=public
REDIS_URL=redis://localhost:6379

# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-random-string-at-least-32-chars-long
JWT_ACCESS_TTL=15m
# Allowlist origin'ов CORS для прода (через запятую). В dev можно не задавать.
# CLIENT_ORIGIN=http://localhost:5173
