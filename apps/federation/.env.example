# Subgraph'ы читают ту же БД, что и монолит
DATABASE_URL=postgresql://social:social@localhost:5432/social?schema=public

# Токены выдаёт монолит, subgraph'ы их только проверяют → секрет ОБЩИЙ с apps/api
JWT_SECRET=change-me-to-match-apps-api

GATEWAY_PORT=4000
USERS_PORT=4001
POSTS_PORT=4002
ENGAGEMENT_PORT=4003

# subgraph'ы — внутренние процессы (наружу смотрит только gateway)
SUBGRAPH_HOST=127.0.0.1
GATEWAY_HOST=0.0.0.0

GRAPHQL_MAX_DEPTH=12
POSTS_PER_AUTHOR=20

# в production обязателен: allowlist origin'ов для CORS gateway
# CLIENT_ORIGIN=https://example.com
