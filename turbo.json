{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    // codegen фронта (apps/web) читает code-first схему бэкенда (файл, не живой
    // сервер). Скрипт есть только у web — для apps/api это no-op.
    "codegen": {
      "inputs": ["../api/src/schema.gql", "src/**/*.{ts,tsx}", "codegen.ts"],
      "outputs": ["src/gql/**"]
    },
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": ["dist/**"]
    },
    "start": {
      // `nest start` сам компилирует из исходников (и с deleteOutDir чистит dist),
      // поэтому зависимость от build тут не нужна — это был бы двойной компайл.
      "cache": false,
      "persistent": true
    },
    "start:prod": {
      // прод-запуск из готового dist (node dist/main.js) — вот здесь build обязателен.
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build", "codegen"]
    }
  }
}
